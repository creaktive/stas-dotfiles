#!/bin/bash
AWS=aws
DATE=$(which gdate || which date)
JQ=jq

$DATE -d tomorrow &>/dev/null
if [ $? -ne 0 ]; then
    echo "Incompatible date command" &>2
    exit 1
fi

startTime=yesterday
endTime=now
limit=10000
groupNameFilter=lambda
describe=

ARGS=()
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            cat << HELP
Usage: aws-logs-query-all [options...] <query>
 -h, --help         This
 -f, --from         Search from timestamp (default: yesterday)
 -t, --to           Search to timestamp (default: now)
 -l, --limit        Results limit (default: 10000)
 -g, --group        Match group names to substring (default: lambda)
 -d, --describe     Describe non-empty matching groups and exit
HELP
            exit
            ;;
        -f|--from)
            startTime="$2"
            shift
            shift
            ;;
        -t|--to)
            endTime="$2"
            shift
            shift
            ;;
        -l|--limit)
            limit="$2"
            shift
            shift
            ;;
        -g|--group)
            groupNameFilter="$2"
            shift
            shift
            ;;
        -d|--describe)
            describe=1
            shift
            ;;
        -*|--*)
            echo "Unknown option $1"
            exit 1
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

query="${ARGS[@]:-fields @message | filter @message like /^\{/ | sort @timestamp asc}"

tmpDir=$(mktemp -d)
if [ $? -ne 0 ]; then
    echo "Can't create temporary dir" &>2
    exit 1
fi
cd $tmpDir

groups='groups.json'
$AWS logs describe-log-groups \
    | $JQ "
        .logGroups[]
        | select(
            (.storedBytes > 0) and
            (.logGroupName | test(\"$groupNameFilter\"))
        )
    " > $groups

if [ -n "$describe" ]; then
    $JQ < $groups
    rm -rf $tmpDir
    exit
fi

$JQ -r ".logGroupName" < $groups \
    | shuf \
    | split -l 50 - subgroup

rm $groups

QUERIES=()
for subgroup in subgroup*
do
    queryId=$(
        $AWS logs start-query \
            --limit $limit \
            --start-time $($DATE -d "$startTime" +%s) \
            --end-time $($DATE -d "$endTime" +%s) \
            --log-group-names $(cat $subgroup) \
            --query-string "$query" \
            | $JQ -r .queryId
    )
    QUERIES+=($queryId)
    rm $subgroup
    echo $AWS logs get-query-results --query-id $queryId >&2
done

rmdir $tmpDir

for queryId in "${QUERIES[@]}"
do
    while true; do
        $AWS logs get-query-results \
            --query-id $queryId \
            | $JQ '
                if .status == "Running" then
                    .statistics
                    | halt_error(1)
                else
                    .results[]
                    | map({(.field | sub("\\W"; "_"; "g")): .value})
                    | add
                    | ._message? | fromjson?
                    | {timestamp} + .
                end
            ' && break
        sleep 1
    done
done

exit 0
